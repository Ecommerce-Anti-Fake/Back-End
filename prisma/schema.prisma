generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DistributionNodeType {
  MANUFACTURER
  AGENT_LEVEL_1
  AGENT_LEVEL_2
  AGENT_LEVEL_3
}

enum DistributionRelationshipStatus {
  INVITED
  DECLINED
  ACTIVE
  SUSPENDED
  TERMINATED
  EXPIRED
}

enum DistributionShipmentStatus {
  DRAFT
  IN_TRANSIT
  DELIVERED
  CANCELLED
  RETURNED
}

enum AffiliateScopeType {
  PLATFORM
  SHOP
  BRAND
  PRODUCT_MODEL
  OFFER
}

enum AffiliateProgramStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum AffiliateAccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum AffiliateConversionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AffiliateCommissionStatus {
  PENDING
  APPROVED
  LOCKED
  PAID
  CANCELLED
}

enum CommissionBeneficiaryType {
  AFFILIATE_TIER_1
  AFFILIATE_TIER_2
  PLATFORM
  SHOP
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum ShopRegistrationType {
  NORMAL
  HANDMADE
  MANUFACTURER
  DISTRIBUTOR
}

enum OfferSalesMode {
  RETAIL
  WHOLESALE
  BOTH
}

enum DistributionDiscountType {
  PERCENT
  FIXED_AMOUNT
  FIXED_PRICE
}

enum DistributionPricingScope {
  NETWORK_DEFAULT
  NODE_LEVEL
  NODE_SPECIFIC
}

enum OrderMode {
  RETAIL
  WHOLESALE
}

enum MediaProvider {
  CLOUDINARY
}

enum MediaAssetType {
  IMAGE
  VIDEO
  RAW
}

enum MediaResourceType {
  DISPUTE_EVIDENCE
  KYC_DOCUMENT
  SHOP_DOCUMENT
  PRODUCT_IMAGE
  OFFER_DOCUMENT
  BATCH_DOCUMENT
}

enum KycDocumentSide {
  FRONT
  BACK
}

model User {
  id                   String                @id @default(uuid())
  phone                String?               @unique
  email                String?               @unique
  displayName          String?               @map("display_name")
  password             String?
  address              String?
  role                 String                @default("user")
  accountStatus        String                @default("active") @map("account_status")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  authSessions         AuthSession[]
  kyc                  UserKyc?
  ownedShops           Shop[]                @relation("ShopOwner")
  offers               Offer[]               @relation("OfferSeller")
  carts                Cart[]
  orders               Order[]               @relation("OrderBuyer")
  disputesOpened       Dispute[]             @relation("DisputeOpenedBy")
  disputeEvidence      DisputeEvidence[]     @relation("DisputeEvidenceUploadedBy")
  mediaAssets          MediaAsset[]          @relation("MediaAssetOwner")
  auditLogs            AuditLog[]            @relation("AuditLogActor")
  reviewsGiven         Review[]              @relation("ReviewFromUser")
  reviewsReceived      Review[]              @relation("ReviewToUser")
  chatThreadsAsBuyer   ChatThread[]          @relation("ChatThreadBuyer")
  chatThreadsAsSeller  ChatThread[]          @relation("ChatThreadSeller")
  chatMessages         ChatMessage[]         @relation("ChatMessageSender")
  reports              Report[]              @relation("ReportReporter")
  moderationCases      ModerationCase[]      @relation("ModerationCaseAssignee")
  provenanceEvents     ProvenanceEvent[]     @relation("ProvenanceEventActor")
  affiliateAccounts    AffiliateAccount[]
  affiliateConversions AffiliateConversion[] @relation("AffiliateConversionCustomer")

  @@map("user")
}

model MediaAsset {
  id                        String                     @id @default(uuid())
  ownerUserId               String                     @map("owner_user_id")
  provider                  MediaProvider
  assetType                 MediaAssetType             @map("asset_type")
  resourceType              MediaResourceType          @map("resource_type")
  publicId                  String?                    @map("public_id")
  secureUrl                 String                     @map("secure_url")
  mimeType                  String?                    @map("mime_type")
  folder                    String?                    @map("folder")
  uploadedAt                DateTime                   @default(now()) @map("uploaded_at")
  owner                     User                       @relation("MediaAssetOwner", fields: [ownerUserId], references: [id])
  disputeEvidence           DisputeEvidence[]
  userKycDocument           UserKycDocument?
  shopDocumentFiles         ShopDocumentFile[]
  shopCategoryDocument      ShopCategoryDocument?
  userKycSubmissionDocument UserKycSubmissionDocument?
  offerMedia                OfferMedia?
  offerDocument             OfferDocument?
  batchDocument             BatchDocument?
  brandAuthorization        BrandAuthorization?

  @@index([ownerUserId])
  @@index([resourceType])
  @@map("media_asset")
}

model AuditLog {
  id          String   @id @default(uuid())
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  actorUserId String   @map("actor_user_id")
  action      String
  fromStatus  String?  @map("from_status")
  toStatus    String?  @map("to_status")
  note        String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  actor       User     @relation("AuditLogActor", fields: [actorUserId], references: [id])

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId])
  @@map("audit_log")
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  tokenFamily      String    @map("token_family")
  currentTokenId   String    @unique @map("current_token_id")
  currentTokenHash String    @map("current_token_hash")
  expiresAt        DateTime  @map("expires_at")
  lastUsedAt       DateTime? @map("last_used_at")
  revokedAt        DateTime? @map("revoked_at")
  reuseDetectedAt  DateTime? @map("reuse_detected_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenFamily])
  @@map("auth_session")
}

model UserKyc {
  id                 String              @id @default(uuid())
  userId             String              @unique @map("user_id")
  fullName           String              @map("full_name")
  dateOfBirth        DateTime            @map("date_of_birth")
  kycLevel           String              @map("kyc_level")
  idType             String              @map("id_type")
  idNumberHash       String              @map("id_number_hash")
  verificationStatus String              @map("verification_status")
  verifiedAt         DateTime?           @map("verified_at")
  reviewNote         String?             @map("review_note")
  user               User                @relation(fields: [userId], references: [id])
  documents          UserKycDocument[]
  submissions        UserKycSubmission[]

  @@map("user_kyc")
}

model UserKycDocument {
  id           String          @id @default(uuid())
  userKycId    String          @map("user_kyc_id")
  mediaAssetId String          @map("media_asset_id")
  side         KycDocumentSide
  uploadedAt   DateTime        @default(now()) @map("uploaded_at")
  userKyc      UserKyc         @relation(fields: [userKycId], references: [id])
  mediaAsset   MediaAsset      @relation(fields: [mediaAssetId], references: [id])

  @@unique([userKycId, side])
  @@unique([mediaAssetId])
  @@index([userKycId])
  @@map("user_kyc_document")
}

model UserKycSubmission {
  id                 String                      @id @default(uuid())
  userKycId          String                      @map("user_kyc_id")
  submissionNumber   Int                         @map("submission_number")
  verificationStatus String                      @default("pending") @map("verification_status")
  reviewNote         String?                     @map("review_note")
  reviewedAt         DateTime?                   @map("reviewed_at")
  submittedAt        DateTime                    @default(now()) @map("submitted_at")
  userKyc            UserKyc                     @relation(fields: [userKycId], references: [id])
  documents          UserKycSubmissionDocument[]

  @@unique([userKycId, submissionNumber])
  @@index([userKycId, submittedAt])
  @@map("user_kyc_submission")
}

model UserKycSubmissionDocument {
  id           String            @id @default(uuid())
  submissionId String            @map("submission_id")
  mediaAssetId String            @unique @map("media_asset_id")
  side         KycDocumentSide
  uploadedAt   DateTime          @default(now()) @map("uploaded_at")
  submission   UserKycSubmission @relation(fields: [submissionId], references: [id])
  mediaAsset   MediaAsset        @relation(fields: [mediaAssetId], references: [id])

  @@unique([submissionId, side])
  @@index([submissionId])
  @@map("user_kyc_submission_document")
}

model Shop {
  id                         String                 @id @default(uuid())
  ownerUserId                String                 @map("owner_user_id")
  shopTypeId                 String?                @map("shop_type_id")
  shopName                   String                 @map("shop_name")
  registrationType           ShopRegistrationType   @map("registration_type")
  businessType               String                 @map("business_type")
  taxCode                    String?                @map("tax_code")
  shopStatus                 String                 @map("shop_status")
  createdAt                  DateTime               @default(now()) @map("created_at")
  owner                      User                   @relation("ShopOwner", fields: [ownerUserId], references: [id])
  shopType                   ShopType?              @relation(fields: [shopTypeId], references: [id])
  documents                  ShopDocument[]
  registeredCategories       ShopBusinessCategory[]
  brandAuthorizations        BrandAuthorization[]
  offers                     Offer[]
  supplyBatches              SupplyBatch[]
  orders                     Order[]
  wholesaleOrders            Order[]                @relation("OrderBuyerShop")
  distributionNetworksAsRoot DistributionNetwork[]  @relation("DistributionManufacturerShop")
  distributionNodes          DistributionNode[]
  affiliatePrograms          AffiliateProgram[]

  @@index([shopTypeId])
  @@map("shop")
}

model ShopType {
  id           String                @id @default(uuid())
  code         String                @unique
  name         String
  description  String?
  isActive     Boolean               @default(true) @map("is_active")
  sortOrder    Int                   @default(0) @map("sort_order")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  shops        Shop[]
  requirements ShopTypeRequirement[]

  @@index([isActive, sortOrder])
  @@map("shop_type")
}

model VerificationRequirement {
  id                   String                @id @default(uuid())
  code                 String                @unique
  name                 String
  description          String?
  multipleFilesAllowed Boolean               @default(true) @map("multiple_files_allowed")
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  shopTypes            ShopTypeRequirement[]
  shopDocuments        ShopDocument[]

  @@index([isActive])
  @@map("verification_requirement")
}

model ShopTypeRequirement {
  id            String                  @id @default(uuid())
  shopTypeId    String                  @map("shop_type_id")
  requirementId String                  @map("requirement_id")
  required      Boolean                 @default(true)
  sortOrder     Int                     @default(0) @map("sort_order")
  isActive      Boolean                 @default(true) @map("is_active")
  shopType      ShopType                @relation(fields: [shopTypeId], references: [id], onDelete: Cascade)
  requirement   VerificationRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([shopTypeId, requirementId])
  @@index([requirementId])
  @@index([isActive, sortOrder])
  @@map("shop_type_requirement")
}

model ShopBusinessCategory {
  id                 String                 @id @default(uuid())
  shopId             String                 @map("shop_id")
  categoryId         String                 @map("category_id")
  registrationStatus String                 @default("pending") @map("registration_status")
  approvedAt         DateTime?              @map("approved_at")
  reviewNote         String?                @map("review_note")
  createdAt          DateTime               @default(now()) @map("created_at")
  shop               Shop                   @relation(fields: [shopId], references: [id])
  category           Category               @relation(fields: [categoryId], references: [id])
  documents          ShopCategoryDocument[]

  @@unique([shopId, categoryId])
  @@index([shopId])
  @@index([categoryId])
  @@map("shop_business_category")
}

model ShopCategoryDocument {
  id                     String               @id @default(uuid())
  shopBusinessCategoryId String               @map("shop_business_category_id")
  mediaAssetId           String?              @unique @map("media_asset_id")
  documentType           String               @map("document_type")
  fileUrl                String               @map("file_url")
  documentNumber         String?              @map("document_number")
  issuedBy               String?              @map("issued_by")
  issuedAt               DateTime?            @map("issued_at")
  expiresAt              DateTime?            @map("expires_at")
  reviewStatus           String               @default("pending") @map("review_status")
  reviewNote             String?              @map("review_note")
  reviewedAt             DateTime?            @map("reviewed_at")
  uploadedAt             DateTime             @default(now()) @map("uploaded_at")
  shopBusinessCategory   ShopBusinessCategory @relation(fields: [shopBusinessCategoryId], references: [id])
  mediaAsset             MediaAsset?          @relation(fields: [mediaAssetId], references: [id])

  @@index([shopBusinessCategoryId])
  @@map("shop_category_document")
}

model ShopDocument {
  id            String                   @id @default(uuid())
  shopId        String                   @map("shop_id")
  requirementId String?                  @map("requirement_id")
  docType       String                   @map("doc_type")
  reviewStatus  String                   @map("review_status")
  reviewNote    String?                  @map("review_note")
  reviewedAt    DateTime?                @map("reviewed_at")
  uploadedAt    DateTime                 @default(now()) @map("uploaded_at")
  shop          Shop                     @relation(fields: [shopId], references: [id])
  requirement   VerificationRequirement? @relation(fields: [requirementId], references: [id])
  files         ShopDocumentFile[]

  @@index([shopId])
  @@index([requirementId])
  @@index([docType])
  @@map("shop_document")
}

model ShopDocumentFile {
  id             String       @id @default(uuid())
  shopDocumentId String       @map("shop_document_id")
  mediaAssetId   String       @unique @map("media_asset_id")
  fileUrl        String       @map("file_url")
  sortOrder      Int          @default(0) @map("sort_order")
  uploadedAt     DateTime     @default(now()) @map("uploaded_at")
  shopDocument   ShopDocument @relation(fields: [shopDocumentId], references: [id], onDelete: Cascade)
  mediaAsset     MediaAsset   @relation(fields: [mediaAssetId], references: [id])

  @@index([shopDocumentId])
  @@map("shop_document_file")
}

model Brand {
  id                   String                @id @default(uuid())
  name                 String
  registryStatus       String                @map("registry_status")
  createdAt            DateTime              @default(now()) @map("created_at")
  productModels        ProductModel[]
  authorizations       BrandAuthorization[]
  verificationLabels   VerificationLabel[]
  distributionNetworks DistributionNetwork[]
  affiliatePrograms    AffiliateProgram[]

  @@map("brand")
}

model BrandAuthorization {
  id                 String      @id @default(uuid())
  shopId             String      @map("shop_id")
  brandId            String      @map("brand_id")
  mediaAssetId       String?     @unique @map("media_asset_id")
  authorizationType  String      @map("authorization_type")
  fileUrl            String?     @map("file_url")
  verificationStatus String      @map("verification_status")
  reviewNote         String?     @map("review_note")
  verifiedAt         DateTime?   @map("verified_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  shop               Shop        @relation(fields: [shopId], references: [id])
  brand              Brand       @relation(fields: [brandId], references: [id])
  mediaAsset         MediaAsset? @relation(fields: [mediaAssetId], references: [id])

  @@unique([shopId, brandId])
  @@index([mediaAssetId])
  @@map("brand_authorization")
}

model Category {
  id                          String                      @id @default(uuid())
  parentId                    String?                     @map("parent_id")
  name                        String
  riskTier                    String                      @map("risk_tier")
  parent                      Category?                   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children                    Category[]                  @relation("CategoryHierarchy")
  productModels               ProductModel[]
  offers                      Offer[]
  shopBusinessCategories      ShopBusinessCategory[]
  distributionPricingPolicies DistributionPricingPolicy[]

  @@map("category")
}

model ProductModel {
  id                          String                      @id @default(uuid())
  brandId                     String                      @map("brand_id")
  categoryId                  String                      @map("category_id")
  modelName                   String                      @map("model_name")
  gtin                        String?
  verificationPolicy          String                      @map("verification_policy")
  approvalStatus              String                      @map("approval_status")
  createdAt                   DateTime                    @default(now()) @map("created_at")
  brand                       Brand                       @relation(fields: [brandId], references: [id])
  category                    Category                    @relation(fields: [categoryId], references: [id])
  offers                      Offer[]
  supplyBatches               SupplyBatch[]
  shipmentItems               DistributionShipmentItem[]
  affiliatePrograms           AffiliateProgram[]
  distributionPricingPolicies DistributionPricingPolicy[]

  @@index([categoryId])
  @@map("product_model")
}

model Offer {
  id                   String                @id @default(uuid())
  sellerUserId         String                @map("seller_user_id")
  shopId               String                @map("shop_id")
  categoryId           String                @map("category_id")
  productModelId       String                @map("product_model_id")
  distributionNodeId   String?               @map("distribution_node_id")
  title                String
  description          String
  price                Decimal               @db.Decimal(18, 2)
  currency             String
  salesMode            OfferSalesMode        @default(RETAIL) @map("sales_mode")
  minWholesaleQty      Int?                  @map("min_wholesale_qty")
  itemCondition        String                @map("item_condition")
  availableQuantity    Int                   @map("available_quantity")
  verificationLevel    String                @map("verification_level")
  offerStatus          String                @map("offer_status")
  createdAt            DateTime              @default(now()) @map("created_at")
  seller               User                  @relation("OfferSeller", fields: [sellerUserId], references: [id])
  shop                 Shop                  @relation(fields: [shopId], references: [id])
  category             Category              @relation(fields: [categoryId], references: [id])
  productModel         ProductModel          @relation(fields: [productModelId], references: [id])
  distributionNode     DistributionNode?     @relation(fields: [distributionNodeId], references: [id])
  media                OfferMedia[]
  documents            OfferDocument[]
  batchLinks           OfferBatchLink[]
  orderItems           OrderItem[]
  cartItems            CartItem[]
  chatThreads          ChatThread[]
  affiliatePrograms    AffiliateProgram[]
  affiliateConversions AffiliateConversion[]

  @@index([distributionNodeId])
  @@map("offer")
}

model OfferMedia {
  id           String      @id @default(uuid())
  offerId      String      @map("offer_id")
  mediaAssetId String?     @unique @map("media_asset_id")
  mediaType    String      @map("media_type")
  fileUrl      String      @map("file_url")
  phash        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  offer        Offer       @relation(fields: [offerId], references: [id])
  mediaAsset   MediaAsset? @relation(fields: [mediaAssetId], references: [id])

  @@index([mediaAssetId])
  @@map("offer_media")
}

model OfferDocument {
  id                 String      @id @default(uuid())
  offerId            String      @map("offer_id")
  mediaAssetId       String?     @unique @map("media_asset_id")
  docType            String      @map("doc_type")
  fileUrl            String      @map("file_url")
  issuerName         String?     @map("issuer_name")
  documentNumberHash String?     @map("document_number_hash")
  reviewStatus       String      @map("review_status")
  uploadedAt         DateTime    @default(now()) @map("uploaded_at")
  offer              Offer       @relation(fields: [offerId], references: [id])
  mediaAsset         MediaAsset? @relation(fields: [mediaAssetId], references: [id])

  @@index([mediaAssetId])
  @@map("offer_document")
}

model SupplyBatch {
  id                   String                     @id @default(uuid())
  shopId               String                     @map("shop_id")
  productModelId       String                     @map("product_model_id")
  distributionNodeId   String?                    @map("distribution_node_id")
  batchNumber          String                     @map("batch_number")
  quantity             Int                        @map("quantity")
  sourceName           String                     @map("source_name")
  countryOfOrigin      String                     @map("country_of_origin")
  sourceType           String                     @map("source_type")
  receivedAt           DateTime                   @map("received_at")
  shop                 Shop                       @relation(fields: [shopId], references: [id])
  productModel         ProductModel               @relation(fields: [productModelId], references: [id])
  distributionNode     DistributionNode?          @relation(fields: [distributionNodeId], references: [id])
  documents            BatchDocument[]
  offerLinks           OfferBatchLink[]
  orderItemAllocations OrderItemBatchAllocation[]
  shipmentItems        DistributionShipmentItem[]

  @@index([distributionNodeId])
  @@map("supply_batch")
}

model BatchDocument {
  id                 String      @id @default(uuid())
  batchId            String      @map("batch_id")
  mediaAssetId       String?     @unique @map("media_asset_id")
  docType            String      @map("doc_type")
  fileUrl            String      @map("file_url")
  issuerName         String?     @map("issuer_name")
  documentNumberHash String?     @map("document_number_hash")
  reviewStatus       String      @map("review_status")
  uploadedAt         DateTime    @default(now()) @map("uploaded_at")
  batch              SupplyBatch @relation(fields: [batchId], references: [id])
  mediaAsset         MediaAsset? @relation(fields: [mediaAssetId], references: [id])

  @@index([mediaAssetId])
  @@map("batch_document")
}

model OfferBatchLink {
  id                String      @id @default(uuid())
  offerId           String      @map("offer_id")
  batchId           String      @map("batch_id")
  allocatedQuantity Int         @map("allocated_quantity")
  createdAt         DateTime    @default(now()) @map("created_at")
  offer             Offer       @relation(fields: [offerId], references: [id])
  batch             SupplyBatch @relation(fields: [batchId], references: [id])

  @@unique([offerId, batchId])
  @@map("offer_batch_link")
}

model VerificationLabel {
  id          String            @id @default(uuid())
  brandId     String            @map("brand_id")
  labelType   String            @map("label_type")
  codeHash    String            @map("code_hash")
  issuerType  String            @map("issuer_type")
  labelStatus String            @map("label_status")
  scopeType   String            @map("scope_type")
  scopeId     String            @map("scope_id")
  issuedAt    DateTime          @map("issued_at")
  brand       Brand             @relation(fields: [brandId], references: [id])
  provenance  ProvenanceEvent[]

  @@map("verification_label")
}

model ProvenanceEvent {
  id          String            @id @default(uuid())
  labelId     String            @map("label_id")
  eventType   String            @map("event_type")
  actorUserId String            @map("actor_user_id")
  actorRole   String            @map("actor_role")
  channel     String
  contextType String            @map("context_type")
  contextId   String            @map("context_id")
  payloadHash String            @map("payload_hash")
  occurredAt  DateTime          @map("occurred_at")
  label       VerificationLabel @relation(fields: [labelId], references: [id])
  actor       User              @relation("ProvenanceEventActor", fields: [actorUserId], references: [id])

  @@map("provenance_event")
}

model RiskScore {
  id            String   @id @default(uuid())
  targetType    String   @map("target_type")
  targetId      String   @map("target_id")
  score         Decimal  @db.Decimal(5, 2)
  riskLevel     String   @map("risk_level")
  factorSummary String   @map("factor_summary")
  calculatedAt  DateTime @map("calculated_at")

  @@map("risk_score")
}

model Cart {
  id          String     @id @default(uuid())
  buyerUserId String     @map("buyer_user_id")
  cartStatus  String     @default("ACTIVE") @map("cart_status")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  buyer       User       @relation(fields: [buyerUserId], references: [id])
  items       CartItem[]

  @@unique([buyerUserId, cartStatus])
  @@index([buyerUserId])
  @@map("cart")
}

model CartItem {
  id                 String   @id @default(uuid())
  cartId             String   @map("cart_id")
  offerId            String   @map("offer_id")
  quantity           Int
  offerTitleSnapshot String   @map("offer_title_snapshot")
  unitPriceSnapshot  Decimal  @map("unit_price_snapshot") @db.Decimal(18, 2)
  currencySnapshot   String   @map("currency_snapshot")
  shopNameSnapshot   String   @map("shop_name_snapshot")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  cart               Cart     @relation(fields: [cartId], references: [id])
  offer              Offer    @relation(fields: [offerId], references: [id])

  @@unique([cartId, offerId])
  @@index([cartId])
  @@index([offerId])
  @@map("cart_item")
}

model Order {
  id                      String               @id @default(uuid())
  buyerUserId             String?              @map("buyer_user_id")
  buyerShopId             String?              @map("buyer_shop_id")
  buyerDistributionNodeId String?              @map("buyer_distribution_node_id")
  shopId                  String               @map("shop_id")
  orderMode               OrderMode            @default(RETAIL) @map("order_mode")
  orderType               String               @map("order_type")
  orderStatus             String               @map("order_status")
  fulfillmentStatus       String               @default("PENDING") @map("fulfillment_status")
  baseAmount              Decimal              @map("base_amount") @db.Decimal(18, 2)
  discountAmount          Decimal              @default(0) @map("discount_amount") @db.Decimal(18, 2)
  platformFeeAmount       Decimal              @default(0) @map("platform_fee_amount") @db.Decimal(18, 2)
  buyerPayableAmount      Decimal              @map("buyer_payable_amount") @db.Decimal(18, 2)
  sellerReceivableAmount  Decimal              @map("seller_receivable_amount") @db.Decimal(18, 2)
  totalAmount             Decimal              @map("total_amount") @db.Decimal(18, 2)
  shippingName            String?              @map("shipping_name")
  shippingPhone           String?              @map("shipping_phone")
  shippingAddress         String?              @map("shipping_address")
  createdAt               DateTime             @default(now()) @map("created_at")
  buyer                   User?                @relation("OrderBuyer", fields: [buyerUserId], references: [id])
  buyerShop               Shop?                @relation("OrderBuyerShop", fields: [buyerShopId], references: [id])
  buyerDistributionNode   DistributionNode?    @relation("OrderBuyerDistributionNode", fields: [buyerDistributionNodeId], references: [id])
  shop                    Shop                 @relation(fields: [shopId], references: [id])
  items                   OrderItem[]
  paymentIntent           PaymentIntent?
  escrow                  Escrow?
  disputes                Dispute[]
  reviews                 Review[]
  affiliateConversion     AffiliateConversion?

  @@index([buyerUserId])
  @@index([buyerShopId])
  @@index([buyerDistributionNodeId])
  @@map("order")
}

model OrderItem {
  id                        String                     @id @default(uuid())
  orderId                   String                     @map("order_id")
  offerId                   String                     @map("offer_id")
  offerTitleSnapshot        String                     @map("offer_title_snapshot")
  unitPrice                 Decimal                    @map("unit_price") @db.Decimal(18, 2)
  quantity                  Int
  verificationLevelSnapshot String                     @map("verification_level_snapshot")
  order                     Order                      @relation(fields: [orderId], references: [id])
  offer                     Offer                      @relation(fields: [offerId], references: [id])
  batchAllocations          OrderItemBatchAllocation[]

  @@map("order_item")
}

model OrderItemBatchAllocation {
  id          String      @id @default(uuid())
  orderItemId String      @map("order_item_id")
  batchId     String      @map("batch_id")
  quantity    Int
  createdAt   DateTime    @default(now()) @map("created_at")
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id])
  batch       SupplyBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@map("order_item_batch_allocation")
}

model PaymentIntent {
  id            String   @id @default(uuid())
  orderId       String   @unique @map("order_id")
  paymentMethod String   @map("payment_method")
  paymentStatus String   @map("payment_status")
  amount        Decimal  @db.Decimal(18, 2)
  providerRef   String?  @map("provider_ref")
  createdAt     DateTime @default(now()) @map("created_at")
  order         Order    @relation(fields: [orderId], references: [id])

  @@map("payment_intent")
}

model Escrow {
  id           String    @id @default(uuid())
  orderId      String    @unique @map("order_id")
  escrowStatus String    @map("escrow_status")
  heldAmount   Decimal   @map("held_amount") @db.Decimal(18, 2)
  holdAt       DateTime? @map("hold_at")
  releaseAt    DateTime? @map("release_at")
  order        Order     @relation(fields: [orderId], references: [id])

  @@map("escrow")
}

model Dispute {
  id             String            @id @default(uuid())
  orderId        String            @map("order_id")
  openedByUserId String            @map("opened_by_user_id")
  reason         String
  disputeStatus  String            @map("dispute_status")
  openedAt       DateTime          @default(now()) @map("opened_at")
  resolvedAt     DateTime?         @map("resolved_at")
  order          Order             @relation(fields: [orderId], references: [id])
  openedBy       User              @relation("DisputeOpenedBy", fields: [openedByUserId], references: [id])
  evidence       DisputeEvidence[]

  @@map("dispute")
}

model DisputeEvidence {
  id               String      @id @default(uuid())
  disputeId        String      @map("dispute_id")
  uploadedByUserId String      @map("uploaded_by_user_id")
  mediaAssetId     String?     @map("media_asset_id")
  fileType         String      @map("file_type")
  fileUrl          String      @map("file_url")
  uploadedAt       DateTime    @default(now()) @map("uploaded_at")
  dispute          Dispute     @relation(fields: [disputeId], references: [id])
  uploadedBy       User        @relation("DisputeEvidenceUploadedBy", fields: [uploadedByUserId], references: [id])
  mediaAsset       MediaAsset? @relation(fields: [mediaAssetId], references: [id])

  @@index([mediaAssetId])
  @@map("dispute_evidence")
}

model Review {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  order      Order    @relation(fields: [orderId], references: [id])
  fromUser   User     @relation("ReviewFromUser", fields: [fromUserId], references: [id])
  toUser     User     @relation("ReviewToUser", fields: [toUserId], references: [id])

  @@map("review")
}

model ChatThread {
  id           String        @id @default(uuid())
  offerId      String        @map("offer_id")
  buyerUserId  String        @map("buyer_user_id")
  sellerUserId String        @map("seller_user_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  offer        Offer         @relation(fields: [offerId], references: [id])
  buyer        User          @relation("ChatThreadBuyer", fields: [buyerUserId], references: [id])
  seller       User          @relation("ChatThreadSeller", fields: [sellerUserId], references: [id])
  messages     ChatMessage[]

  @@map("chat_thread")
}

model ChatMessage {
  id           String     @id @default(uuid())
  threadId     String     @map("thread_id")
  senderUserId String     @map("sender_user_id")
  messageType  String     @map("message_type")
  body         String
  sentAt       DateTime   @default(now()) @map("sent_at")
  thread       ChatThread @relation(fields: [threadId], references: [id])
  sender       User       @relation("ChatMessageSender", fields: [senderUserId], references: [id])

  @@map("chat_message")
}

model Report {
  id             String   @id @default(uuid())
  reporterUserId String   @map("reporter_user_id")
  targetType     String   @map("target_type")
  targetId       String   @map("target_id")
  reason         String
  reportStatus   String   @map("report_status")
  createdAt      DateTime @default(now()) @map("created_at")
  reporter       User     @relation("ReportReporter", fields: [reporterUserId], references: [id])

  @@map("report")
}

model ModerationCase {
  id                  String    @id @default(uuid())
  targetType          String    @map("target_type")
  targetId            String    @map("target_id")
  reason              String
  caseStatus          String    @map("case_status")
  internalNote        String?   @map("internal_note")
  assignedAdminUserId String?   @map("assigned_admin_user_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  resolvedAt          DateTime? @map("resolved_at")
  assignedAdmin       User?     @relation("ModerationCaseAssignee", fields: [assignedAdminUserId], references: [id])

  @@map("moderation_case")
}

model DistributionNetwork {
  id                 String                      @id @default(uuid())
  brandId            String                      @map("brand_id")
  manufacturerShopId String                      @map("manufacturer_shop_id")
  networkName        String                      @map("network_name")
  networkStatus      String                      @default("active") @map("network_status")
  maxAgentDepth      Int                         @default(3) @map("max_agent_depth")
  rulesJson          Json?                       @map("rules_json")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")
  brand              Brand                       @relation(fields: [brandId], references: [id])
  manufacturerShop   Shop                        @relation("DistributionManufacturerShop", fields: [manufacturerShopId], references: [id])
  nodes              DistributionNode[]
  shipments          DistributionShipment[]
  pricingPolicies    DistributionPricingPolicy[]

  @@unique([brandId, manufacturerShopId])
  @@map("distribution_network")
}

model DistributionNode {
  id                 String                         @id @default(uuid())
  networkId          String                         @map("network_id")
  shopId             String                         @map("shop_id")
  parentNodeId       String?                        @map("parent_node_id")
  level              Int
  nodeType           DistributionNodeType           @map("node_type")
  relationshipStatus DistributionRelationshipStatus @default(ACTIVE) @map("relationship_status")
  contractCode       String?                        @map("contract_code")
  lineageCode        String?                        @map("lineage_code")
  territoryCode      String?                        @map("territory_code")
  activatedAt        DateTime?                      @map("activated_at")
  terminatedAt       DateTime?                      @map("terminated_at")
  createdAt          DateTime                       @default(now()) @map("created_at")
  updatedAt          DateTime                       @updatedAt @map("updated_at")
  network            DistributionNetwork            @relation(fields: [networkId], references: [id])
  shop               Shop                           @relation(fields: [shopId], references: [id])
  parent             DistributionNode?              @relation("DistributionNodeHierarchy", fields: [parentNodeId], references: [id])
  children           DistributionNode[]             @relation("DistributionNodeHierarchy")
  offers             Offer[]
  supplyBatches      SupplyBatch[]
  outboundShipments  DistributionShipment[]         @relation("DistributionShipmentFrom")
  inboundShipments   DistributionShipment[]         @relation("DistributionShipmentTo")
  pricingPolicies    DistributionPricingPolicy[]
  wholesaleOrders    Order[]                        @relation("OrderBuyerDistributionNode")

  @@unique([networkId, shopId])
  @@index([parentNodeId])
  @@index([networkId, level])
  @@map("distribution_node")
}

model DistributionShipment {
  id             String                     @id @default(uuid())
  networkId      String                     @map("network_id")
  fromNodeId     String                     @map("from_node_id")
  toNodeId       String                     @map("to_node_id")
  shipmentCode   String                     @map("shipment_code")
  shipmentStatus DistributionShipmentStatus @default(DRAFT) @map("shipment_status")
  note           String?
  shippedAt      DateTime?                  @map("shipped_at")
  receivedAt     DateTime?                  @map("received_at")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")
  network        DistributionNetwork        @relation(fields: [networkId], references: [id])
  fromNode       DistributionNode           @relation("DistributionShipmentFrom", fields: [fromNodeId], references: [id])
  toNode         DistributionNode           @relation("DistributionShipmentTo", fields: [toNodeId], references: [id])
  items          DistributionShipmentItem[]

  @@unique([networkId, shipmentCode])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("distribution_shipment")
}

model DistributionShipmentItem {
  id             String               @id @default(uuid())
  shipmentId     String               @map("shipment_id")
  batchId        String               @map("batch_id")
  productModelId String               @map("product_model_id")
  quantity       Int
  unitCost       Decimal?             @map("unit_cost") @db.Decimal(18, 2)
  createdAt      DateTime             @default(now()) @map("created_at")
  shipment       DistributionShipment @relation(fields: [shipmentId], references: [id])
  batch          SupplyBatch          @relation(fields: [batchId], references: [id])
  productModel   ProductModel         @relation(fields: [productModelId], references: [id])

  @@index([batchId])
  @@index([productModelId])
  @@map("distribution_shipment_item")
}

model DistributionPricingPolicy {
  id             String                   @id @default(uuid())
  networkId      String                   @map("network_id")
  nodeId         String?                  @map("node_id")
  appliesToLevel Int?                     @map("applies_to_level")
  productModelId String?                  @map("product_model_id")
  categoryId     String?                  @map("category_id")
  scope          DistributionPricingScope @map("scope")
  discountType   DistributionDiscountType @map("discount_type")
  discountValue  Decimal                  @map("discount_value") @db.Decimal(18, 2)
  minQuantity    Int?                     @map("min_quantity")
  priority       Int                      @default(100)
  isActive       Boolean                  @default(true) @map("is_active")
  startsAt       DateTime?                @map("starts_at")
  endsAt         DateTime?                @map("ends_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  network        DistributionNetwork      @relation(fields: [networkId], references: [id])
  node           DistributionNode?        @relation(fields: [nodeId], references: [id])
  productModel   ProductModel?            @relation(fields: [productModelId], references: [id])
  category       Category?                @relation(fields: [categoryId], references: [id])

  @@index([networkId, isActive])
  @@index([nodeId])
  @@index([appliesToLevel])
  @@index([productModelId])
  @@index([categoryId])
  @@map("distribution_pricing_policy")
}

model AffiliateProgram {
  id                    String                 @id @default(uuid())
  ownerShopId           String?                @map("owner_shop_id")
  brandId               String?                @map("brand_id")
  productModelId        String?                @map("product_model_id")
  offerId               String?                @map("offer_id")
  scopeType             AffiliateScopeType     @map("scope_type")
  name                  String
  slug                  String                 @unique
  programStatus         AffiliateProgramStatus @default(DRAFT) @map("program_status")
  attributionWindowDays Int                    @default(30) @map("attribution_window_days")
  commissionModel       String                 @default("revenue_share") @map("commission_model")
  tier1Rate             Decimal                @map("tier1_rate") @db.Decimal(5, 2)
  tier2Rate             Decimal                @map("tier2_rate") @db.Decimal(5, 2)
  rulesJson             Json?                  @map("rules_json")
  startedAt             DateTime?              @map("started_at")
  endedAt               DateTime?              @map("ended_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  ownerShop             Shop?                  @relation(fields: [ownerShopId], references: [id])
  brand                 Brand?                 @relation(fields: [brandId], references: [id])
  productModel          ProductModel?          @relation(fields: [productModelId], references: [id])
  offer                 Offer?                 @relation(fields: [offerId], references: [id])
  accounts              AffiliateAccount[]
  codes                 AffiliateCode[]
  conversions           AffiliateConversion[]
  payouts               AffiliatePayout[]

  @@index([ownerShopId])
  @@index([brandId])
  @@index([productModelId])
  @@index([offerId])
  @@map("affiliate_program")
}

model AffiliateAccount {
  id                String                      @id @default(uuid())
  programId         String                      @map("program_id")
  userId            String                      @map("user_id")
  parentAccountId   String?                     @map("parent_account_id")
  accountStatus     AffiliateAccountStatus      @default(PENDING) @map("account_status")
  referralPath      String?                     @map("referral_path")
  joinedAt          DateTime                    @default(now()) @map("joined_at")
  approvedAt        DateTime?                   @map("approved_at")
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  program           AffiliateProgram            @relation(fields: [programId], references: [id])
  user              User                        @relation(fields: [userId], references: [id])
  parentAccount     AffiliateAccount?           @relation("AffiliateAccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts     AffiliateAccount[]          @relation("AffiliateAccountHierarchy")
  codes             AffiliateCode[]
  tier1Conversions  AffiliateConversion[]       @relation("AffiliateConversionTier1")
  tier2Conversions  AffiliateConversion[]       @relation("AffiliateConversionTier2")
  commissionEntries AffiliateCommissionLedger[]
  payouts           AffiliatePayout[]

  @@unique([programId, userId])
  @@index([parentAccountId])
  @@map("affiliate_account")
}

model AffiliateCode {
  id          String                @id @default(uuid())
  programId   String                @map("program_id")
  accountId   String                @map("account_id")
  code        String                @unique
  landingUrl  String?               @map("landing_url")
  isDefault   Boolean               @default(false) @map("is_default")
  expiresAt   DateTime?             @map("expires_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  program     AffiliateProgram      @relation(fields: [programId], references: [id])
  account     AffiliateAccount      @relation(fields: [accountId], references: [id])
  conversions AffiliateConversion[]

  @@index([programId])
  @@index([accountId])
  @@map("affiliate_code")
}

model AffiliateConversion {
  id                String                      @id @default(uuid())
  programId         String                      @map("program_id")
  orderId           String?                     @unique @map("order_id")
  offerId           String?                     @map("offer_id")
  affiliateCodeId   String?                     @map("affiliate_code_id")
  tier1AccountId    String                      @map("tier1_account_id")
  tier2AccountId    String?                     @map("tier2_account_id")
  customerUserId    String?                     @map("customer_user_id")
  conversionStatus  AffiliateConversionStatus   @default(PENDING) @map("conversion_status")
  orderAmount       Decimal?                    @map("order_amount") @db.Decimal(18, 2)
  commissionBase    Decimal?                    @map("commission_base") @db.Decimal(18, 2)
  metadata          Json?
  recordedAt        DateTime                    @default(now()) @map("recorded_at")
  approvedAt        DateTime?                   @map("approved_at")
  program           AffiliateProgram            @relation(fields: [programId], references: [id])
  order             Order?                      @relation(fields: [orderId], references: [id])
  offer             Offer?                      @relation(fields: [offerId], references: [id])
  affiliateCode     AffiliateCode?              @relation(fields: [affiliateCodeId], references: [id])
  tier1Account      AffiliateAccount            @relation("AffiliateConversionTier1", fields: [tier1AccountId], references: [id])
  tier2Account      AffiliateAccount?           @relation("AffiliateConversionTier2", fields: [tier2AccountId], references: [id])
  customerUser      User?                       @relation("AffiliateConversionCustomer", fields: [customerUserId], references: [id])
  commissionEntries AffiliateCommissionLedger[]

  @@index([programId])
  @@index([offerId])
  @@index([affiliateCodeId])
  @@index([tier1AccountId])
  @@index([tier2AccountId])
  @@index([customerUserId])
  @@map("affiliate_conversion")
}

model AffiliateCommissionLedger {
  id                   String                    @id @default(uuid())
  conversionId         String                    @map("conversion_id")
  beneficiaryAccountId String?                   @map("beneficiary_account_id")
  beneficiaryType      CommissionBeneficiaryType @map("beneficiary_type")
  tierLevel            Int?                      @map("tier_level")
  amount               Decimal                   @db.Decimal(18, 2)
  currency             String                    @default("VND")
  commissionStatus     AffiliateCommissionStatus @default(PENDING) @map("commission_status")
  lockedAt             DateTime?                 @map("locked_at")
  paidAt               DateTime?                 @map("paid_at")
  payoutId             String?                   @map("payout_id")
  createdAt            DateTime                  @default(now()) @map("created_at")
  conversion           AffiliateConversion       @relation(fields: [conversionId], references: [id])
  beneficiaryAccount   AffiliateAccount?         @relation(fields: [beneficiaryAccountId], references: [id])
  payout               AffiliatePayout?          @relation(fields: [payoutId], references: [id])

  @@index([conversionId])
  @@index([beneficiaryAccountId])
  @@index([payoutId])
  @@map("affiliate_commission_ledger")
}

model AffiliatePayout {
  id                String                      @id @default(uuid())
  programId         String                      @map("program_id")
  accountId         String                      @map("account_id")
  periodStart       DateTime                    @map("period_start")
  periodEnd         DateTime                    @map("period_end")
  totalAmount       Decimal                     @map("total_amount") @db.Decimal(18, 2)
  currency          String                      @default("VND")
  payoutStatus      PayoutStatus                @default(PENDING) @map("payout_status")
  externalRef       String?                     @map("external_ref")
  paidAt            DateTime?                   @map("paid_at")
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  program           AffiliateProgram            @relation(fields: [programId], references: [id])
  account           AffiliateAccount            @relation(fields: [accountId], references: [id])
  commissionEntries AffiliateCommissionLedger[]

  @@index([programId])
  @@index([accountId])
  @@map("affiliate_payout")
}
